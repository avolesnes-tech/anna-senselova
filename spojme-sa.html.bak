<script>

  /* =============================================
     UNIFIED NAV — hamburger + dropdown
     ============================================= */
  (function() {
    var hamburger = document.getElementById('hamburger');
    var navMenu = document.getElementById('nav-menu');
    if (!hamburger || !navMenu) return;

    function isMobile() { return window.innerWidth <= 768; }

    function closeAllDropdowns() {
      navMenu.querySelectorAll('.dropdown').forEach(function(d) {
        d.classList.remove('open', 'dropdown-open');
      });
    }

    function closeMenu() {
      navMenu.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
      closeAllDropdowns();
    }

    // Hamburger toggle
    hamburger.addEventListener('click', function() {
      var isOpen = navMenu.classList.toggle('open');
      hamburger.classList.toggle('open', isOpen);
      hamburger.setAttribute('aria-expanded', String(isOpen));
    });

    // Mobile: tap top-level link that has dropdown → toggle dropdown
    navMenu.querySelectorAll('li > a').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var li = this.closest('li');
        var dd = li.querySelector('.dropdown');
        if (dd && isMobile()) {
          e.preventDefault();
          var isOpen = dd.classList.toggle('open');
          // Close other open dropdowns
          navMenu.querySelectorAll('.dropdown.open').forEach(function(d) {
            if (d !== dd) d.classList.remove('open');
          });
        } else if (!dd) {
          // Plain link — close the menu after short delay so page transition works
          closeMenu();
        }
      });
    });

    // Mobile: clicking a dropdown link closes the menu
    navMenu.querySelectorAll('.dropdown a').forEach(function(a) {
      a.addEventListener('click', function() { closeMenu(); });
    });

    // Desktop: hover with delay so mouse can travel to dropdown
    navMenu.querySelectorAll('li').forEach(function(li) {
      var dd = li.querySelector('.dropdown');
      if (!dd) return;
      var timer;
      function show() {
        if (isMobile()) return;
        clearTimeout(timer);
        dd.classList.add('dropdown-open');
      }
      function scheduleHide() {
        if (isMobile()) return;
        timer = setTimeout(function() { dd.classList.remove('dropdown-open'); }, 140);
      }
      li.addEventListener('mouseenter', show);
      li.addEventListener('mouseleave', scheduleHide);
      dd.addEventListener('mouseenter', function() { clearTimeout(timer); });
      dd.addEventListener('mouseleave', scheduleHide);
    });

    // Close menu when clicking outside
    document.addEventListener('click', function(e) {
      if (!navMenu.contains(e.target) && !hamburger.contains(e.target)) {
        closeMenu();
      }
    });

    // Close mobile menu on resize to desktop
    window.addEventListener('resize', function() {
      if (!isMobile()) {
        closeMenu();
        closeAllDropdowns();
      }
    });

    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeMenu();
    });

    // Highlight active page
    var path = window.location.pathname.split('/').pop() || 'index.html';
    navMenu.querySelectorAll('a[href]').forEach(function(a) {
      var href = a.getAttribute('href').split('#')[0].split('/').pop();
      if (href === path) { a.classList.add('active'); }
    });
  })();

  /* =============================================
     PAGE TRANSITION (fade out on navigate)
     ============================================= */
  document.addEventListener('click', function(e) {
    var link = e.target.closest('a[href]');
    if (!link) return;
    var href = link.getAttribute('href');
    if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto') || link.target === '_blank') return;
    e.preventDefault();
    document.body.classList.add('page-leaving');
    setTimeout(function() { window.location.href = href; }, 340);
  });

  /* =============================================
     READING PROGRESS BAR
     ============================================= */
  (function() {
    var bar = document.getElementById('readingProgress');
    if (!bar) return;
    function upd() {
      var s = window.scrollY;
      var h = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = (h > 0 ? Math.min(s/h*100, 100) : 0) + '%';
    }
    window.addEventListener('scroll', upd, { passive: true });
    upd();
  })();

  function handleSubmit(e) {
    e.preventDefault();
    document.getElementById('contact-form').style.display = 'none';
    document.getElementById('confirm-msg').style.display = 'block';
    window.scrollTo({ top: document.getElementById('confirm-msg').offsetTop - 100, behavior: 'smooth' });
  }
</script>
</body>
</html>
