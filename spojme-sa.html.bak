<!DOCTYPE html>
<html lang="sk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Spojme sa – Vyšívané poklady Anny Šenšelovej</title>
<meta name="description" content="Kontaktujte nás — zdieľajte rodinné príbehy, výšivky alebo spomienky späté s Annou Šenšelovou.">
<meta property="og:title" content="Spojme sa – Vyšívané poklady Anny Šenšelovej">
<meta property="og:description" content="Kontakt a spolupráca — zdieľajte rodinné príbehy a výšivky.">
<meta property="og:image" content="https://avolesnes-tech.github.io/anna-senselova/hero1.jpg">
<meta property="og:type" content="website">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Pinyon+Script&family=Cinzel:wght@400;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --cream: #F9F7F2; --ink: #1A1A1A; --red: #C41E3A;
  --gold: #D4AF37; --gold-dark: #A07C10; --section-alt: #F2EDE4;
}
html { scroll-behavior: smooth; }
body { background: var(--cream); color: var(--ink); font-family: 'Cormorant Garamond', serif; font-size: 19px; line-height: 1.7; overflow-x: hidden; }

/* NAV */
nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(249,247,242,0.96); backdrop-filter: blur(6px); border-bottom: 1px solid var(--gold); display: flex; align-items: center; justify-content: space-between; padding: 0.6rem 2.5rem; }
nav .logo { font-family: 'Pinyon Script', cursive; font-size: 2rem; color: var(--red); text-decoration: none; }
.nav-breadcrumb { font-family: 'Cinzel', serif; font-size: 0.72rem; letter-spacing: 0.12em; color: #767676; text-transform: uppercase; }
.nav-breadcrumb span { color: var(--red); }
.nav-back { font-family: 'Cinzel', serif; font-size: 0.78rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold-dark); text-decoration: none; transition: color 0.3s; }
.nav-back:hover { color: var(--red); }

/* HERO */
#hero { min-height: 50vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 8rem 2rem 4rem; background: var(--cream); position: relative; overflow: hidden; }
#hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 50%, rgba(196,30,58,0.06) 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, rgba(212,175,55,0.07) 0%, transparent 60%); pointer-events: none; }
#hero > * { position: relative; z-index: 1; }

.section-label { font-family: 'Cinzel', serif; font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--red); margin-bottom: 0.6rem; }
h1 { font-family: 'Pinyon Script', cursive; font-size: clamp(3.5rem, 8vw, 7rem); color: var(--red); line-height: 1.75; }
.gold-line { width: 120px; height: 1px; background: linear-gradient(90deg, transparent, var(--gold), transparent); margin: 1.2rem auto; }

/* CONTENT */
.content-wrap { max-width: 780px; margin: 0 auto; padding: 5rem 2rem 3rem; }

.intro-block { text-align: center; margin-bottom: 4rem; }
.intro-block p { font-size: 1.1rem; color: #444; line-height: 1.9; margin-bottom: 1rem; }
.intro-block .highlight { font-style: italic; font-size: 1.2rem; color: var(--ink); border-left: 3px solid var(--red); padding-left: 1.2rem; text-align: left; margin: 2rem 0; }

/* DÔVODY NA KONTAKT */
.reasons { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; margin: 3rem 0; }
.reason-card { background: var(--section-alt); padding: 1.5rem; border-top: 2px solid var(--red); }
.reason-card h3 { font-family: 'Cinzel', serif; font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 0.6rem; }
.reason-card p { font-size: 0.95rem; color: #555; line-height: 1.7; font-style: italic; }

/* INŠPIRÁCIA */
.inspiration { background: var(--red); color: var(--cream); padding: 4rem 2rem; text-align: center; margin: 0; }
.inspiration h2 { font-family: 'Pinyon Script', cursive; font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.75; margin-bottom: 1rem; }
.inspiration p { font-size: 1.05rem; max-width: 600px; margin: 0 auto 0.5rem; opacity: 0.9; font-style: italic; }

/* FORMULÁR */
.form-wrap { max-width: 780px; margin: 0 auto; padding: 5rem 2rem; }
.form-wrap h2 { font-family: 'Pinyon Script', cursive; font-size: clamp(2.5rem, 5vw, 4rem); color: var(--red); line-height: 1.75; text-align: center; margin-bottom: 0.5rem; }
.form-wrap .gold-line { margin: 0.8rem auto 2.5rem; }

.form-group { margin-bottom: 1.5rem; }
.form-group label { display: block; font-family: 'Cinzel', serif; font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: var(--gold-dark); margin-bottom: 0.5rem; }
.form-group input,
.form-group select,
.form-group textarea { width: 100%; padding: 0.8rem 1rem; font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; border: 1px solid var(--gold); background: var(--cream); color: var(--ink); outline: none; transition: border-color 0.3s; letter-spacing: 0.03em; resize: vertical; }
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus { border-color: var(--red); }
.form-group textarea { min-height: 180px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; }

.btn-submit { display: block; width: 100%; padding: 1rem 2rem; font-family: 'Cinzel', serif; font-size: 0.85rem; letter-spacing: 0.18em; text-transform: uppercase; border: 1px solid var(--red); color: var(--red); background: transparent; cursor: pointer; transition: background 0.3s, color 0.3s; margin-top: 0.5rem; }
.btn-submit:hover { background: var(--red); color: var(--cream); }

.form-note { font-size: 0.82rem; color: #767676; font-style: italic; text-align: center; margin-top: 1rem; }

#confirm-msg { display: none; text-align: center; padding: 2rem; }
#confirm-msg h3 { font-family: 'Pinyon Script', cursive; font-size: 2.5rem; color: var(--red); line-height: 1.75; margin-bottom: 0.5rem; }
#confirm-msg p { font-size: 1rem; color: #555; font-style: italic; }

/* FOOTER */
/* FOOTER */
footer { background: #111; color: var(--cream); text-align: center; padding: 4rem 2rem 2.5rem; }
.footer-top { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 3rem; max-width: 860px; margin: 0 auto 3rem; text-align: left; }
.footer-col-center { text-align: center; }
.footer-name { font-family: 'Pinyon Script', cursive; font-size: 2.5rem; color: var(--gold); margin-bottom: 0.5rem; }
.footer-tagline { font-size: 0.85rem; letter-spacing: 0.1em; opacity: 0.7; font-style: italic; margin-top: 0.5rem; text-transform: none; }
.footer-col-title { font-family: 'Cinzel', serif; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold-dark); margin-bottom: 1rem; opacity: 0.9; }
.footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
.footer-links a { text-decoration: none; font-family: 'Cormorant Garamond', serif; font-size: 0.9rem; color: var(--cream); opacity: 0.85; letter-spacing: 0.06em; transition: opacity 0.3s, color 0.3s; }
.footer-links a:hover { opacity: 1; color: var(--gold); }
.footer-divider { width: 100%; height: 1px; background: rgba(212,175,55,0.15); margin: 0 auto 1.5rem; max-width: 860px; }
.footer-copy { font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.85; }
.footer-disclaimer { margin-top: 1rem; font-size: 0.85rem; opacity: 0.8; max-width: 560px; margin-left: auto; margin-right: auto; line-height: 1.75; font-style: italic; text-transform: none; letter-spacing: 0.02em; }
@media (max-width: 700px) { .footer-top { grid-template-columns: 1fr; gap: 2rem; text-align: center; } .footer-col-center { order: -1; } }


@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } .reasons { grid-template-columns: 1fr; } }

/* =============================================
   PAGE TRANSITION
   ============================================= */

/* ── page transition ── */
body { opacity: 1; transition: opacity 0.34s ease; overflow-x: hidden; }
body.page-leaving { opacity: 0; }


/* =============================================
   NAV + HAMBURGER + DROPDOWN — unified
   ============================================= */

/* =============================================
   SKIP LINK — accessibility
   ============================================= */
.skip-link {
  position: absolute; top: -100%; left: 1rem;
  background: var(--red); color: #fff;
  padding: 0.55rem 1.2rem;
  font-family: 'Cinzel', serif; font-size: 0.78rem;
  letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none; z-index: 99999;
  transition: top 0.2s ease;
  border-bottom: 2px solid var(--gold);
}
.skip-link:focus { top: 0; }

/* =============================================
   READING PROGRESS BAR
   ============================================= */
.reading-progress {
  position: fixed; top: var(--nav-height); left: 0;
  width: 0%; height: 2px;
  background: linear-gradient(90deg, var(--red), var(--gold));
  z-index: 9997; transition: width 0.1s linear; pointer-events: none;
}

/* =============================================
   NAV — unified for all pages
   ============================================= */
nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 9998;
  background: rgba(249,247,242,0.96);
  backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
  border-bottom: 1px solid var(--gold);
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 2.5rem;
  height: var(--nav-height);
}

nav .logo {
  font-family: 'Pinyon Script', cursive;
  font-size: 2rem; color: var(--red);
  text-decoration: none; flex-shrink: 0;
  line-height: 1;
}

nav ul {
  list-style: none; display: flex;
  gap: 1.8rem; align-items: center;
}

nav ul li { position: relative; }

nav ul li > a {
  text-decoration: none;
  font-family: 'Cormorant Garamond', serif;
  font-size: 0.88rem; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--ink);
  transition: color 0.3s; display: flex;
  align-items: center; gap: 0.3rem;
  padding: 0.5rem 0; white-space: nowrap;
}
nav ul li > a:hover { color: var(--red); }
nav ul li > a.active { color: var(--red); }

nav ul li > a:focus-visible,
.hamburger:focus-visible {
  outline: 2px solid var(--gold); outline-offset: 3px;
}

/* ── DROPDOWN (desktop) ── */
.dropdown {
  position: absolute; top: 100%; left: 50%;
  transform: translateX(-50%) translateY(6px);
  background: #fff;
  border: 1px solid var(--gold); border-top: 2px solid var(--red);
  min-width: 240px;
  box-shadow: 0 8px 32px rgba(0,0,0,0.10);
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s ease, transform 0.25s ease;
  z-index: 200; padding-top: 8px;
}
/* invisible bridge — keeps hover alive crossing the gap */
.dropdown::before {
  content: ''; position: absolute; top: -8px; left: 0; right: 0;
  height: 8px; background: transparent;
}
.dropdown.dropdown-open {
  opacity: 1; pointer-events: all;
  transform: translateX(-50%) translateY(0);
}
.dropdown a {
  display: block; padding: 0.65rem 1.2rem;
  font-family: 'Cormorant Garamond', serif;
  font-size: 0.88rem; letter-spacing: 0.07em;
  color: var(--ink); text-decoration: none;
  border-bottom: 1px solid rgba(212,175,55,0.15);
  transition: background 0.2s, color 0.2s;
  white-space: nowrap;
}
.dropdown a:last-child { border-bottom: none; }
.dropdown a:hover { background: #fdf8f0; color: var(--red); }
.dropdown a:focus-visible { outline: 2px solid var(--gold); outline-offset: -2px; }
.dropdown .dropdown-label {
  display: block; padding: 0.5rem 1.2rem 0.3rem;
  font-size: 0.7rem; letter-spacing: 0.15em;
  text-transform: uppercase; color: var(--gold-dark);
  border-bottom: 1px solid rgba(212,175,55,0.3);
  font-family: 'Cinzel', serif;
}

/* ── HAMBURGER ── */
.hamburger {
  display: none; flex-direction: column;
  justify-content: center; gap: 5px;
  background: none; border: none;
  cursor: pointer; padding: 0.5rem;
  z-index: 10001; flex-shrink: 0;
}
.hamburger span {
  display: block; width: 24px; height: 2px;
  background: var(--ink); border-radius: 2px;
  transition: transform 0.3s ease, opacity 0.3s ease;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── MOBILE NAV ── */
@media (max-width: 768px) {
  nav { padding: 0 1.2rem; }
  nav .logo { font-size: 1.5rem; }
  .hamburger { display: flex; }

  nav ul {
    display: none; flex-direction: column; gap: 0;
    position: absolute; top: 100%; left: 0; right: 0;
    width: 100%;
    /* Key fix: allow full height scrolling without clipping text */
    max-height: calc(100vh - var(--nav-height));
    overflow-y: auto; -webkit-overflow-scrolling: touch;
    background: rgba(249,247,242,0.99);
    backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
    padding: 0.75rem 1.5rem 2rem;
    align-items: flex-start;
    z-index: 10000;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    border-bottom: 2px solid var(--gold);
  }
  nav ul.open { display: flex; }

  nav ul li {
    width: 100%;
    border-bottom: 1px solid rgba(212,175,55,0.2);
  }
  nav ul li:last-child { border-bottom: none; }

  nav ul li > a {
    font-size: 1rem; font-weight: 400;
    /* Critical: ensure full width tap area and visible text */
    padding: 0.85rem 0;
    width: 100%;
    justify-content: space-between;
    white-space: normal; /* allow wrapping if needed */
    line-height: 1.4;
  }

  /* Mobile dropdown — static, slides open */
  .dropdown {
    position: static; transform: none;
    opacity: 1; pointer-events: none;
    box-shadow: none; border: none;
    border-top: 1px solid rgba(212,175,55,0.2);
    background: rgba(242,237,228,0.7);
    display: none; min-width: unset; width: 100%;
    padding-top: 0;
  }
  .dropdown.open { display: block; pointer-events: auto; }
  .dropdown a {
    padding: 0.65rem 1rem 0.65rem 1.4rem;
    font-size: 0.95rem;
    white-space: normal; /* allow full text to show */
    line-height: 1.4;
  }
  .dropdown .dropdown-label {
    padding: 0.5rem 1rem 0.4rem 1.4rem;
    font-size: 0.65rem;
  }
  /* Disable desktop hover on mobile */
  nav ul li > a:hover .dropdown,
  nav ul li:hover .dropdown { opacity: 1; pointer-events: none; display: none; }
  nav ul li .dropdown.open { display: block !important; pointer-events: auto !important; }
}


/* =============================================
   FOOTER — unified
   ============================================= */

/* =============================================
   FOOTER — unified
   ============================================= */
footer {
  background: #111; color: var(--cream);
  text-align: center; padding: 4rem 2rem 2.5rem;
}
.footer-top {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 3rem; max-width: 860px; margin: 0 auto 3rem;
  text-align: left;
}
.footer-col-center { text-align: center; }
.footer-name {
  font-family: 'Pinyon Script', cursive;
  font-size: 2.5rem; color: var(--gold); margin-bottom: 0.5rem;
}
.footer-tagline {
  font-size: 0.85rem; letter-spacing: 0.1em;
  opacity: 0.7; font-style: italic; margin-top: 0.5rem;
}
.footer-col-title {
  font-family: 'Cinzel', serif; font-size: 0.7rem;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--gold-dark); margin-bottom: 1rem; opacity: 0.9;
}
.footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
.footer-links a {
  text-decoration: none;
  font-family: 'Cormorant Garamond', serif;
  font-size: 0.9rem; color: var(--cream);
  opacity: 0.85; letter-spacing: 0.06em;
  transition: opacity 0.3s, color 0.3s;
}
.footer-links a:hover { opacity: 1; color: var(--gold); }
.footer-links a:focus-visible { outline: 2px solid var(--gold); outline-offset: 2px; }
.footer-divider {
  width: 100%; height: 1px;
  background: rgba(212,175,55,0.15);
  margin: 0 auto 1.5rem; max-width: 860px;
}
.footer-copy { font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.85; }
.footer-disclaimer {
  margin-top: 1rem; font-size: 0.85rem; opacity: 0.8;
  max-width: 560px; margin-left: auto; margin-right: auto;
  line-height: 1.75; font-style: italic; text-transform: none;
  letter-spacing: 0.02em;
}
@media (max-width: 768px) {
  .footer-top { grid-template-columns: 1fr; gap: 2rem; text-align: center; }
  .footer-col-center { order: -1; }
}



/* ── OFFER BLOCK ── */
.offer-block {
  background: var(--section-alt);
  padding: 4rem 2rem;
  margin: 0 -2rem 3.5rem;
}
.offer-inner {
  max-width: 860px;
  margin: 0 auto;
}
.offer-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.offer-card {
  background: var(--cream);
  border-top: 2px solid var(--red);
  border: 1px solid rgba(212,175,55,0.35);
  border-top: 2px solid var(--red);
  padding: 1.8rem 1.5rem;
  transition: box-shadow 0.3s;
}
.offer-card:hover { box-shadow: 0 4px 20px rgba(196,30,58,0.1); }
.offer-icon {
  font-size: 1.1rem;
  color: var(--gold-dark);
  margin-bottom: 0.8rem;
  letter-spacing: 0.2em;
}
.offer-card h3 {
  font-family: 'Cinzel', serif;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 0.7rem;
}
.offer-card p {
  font-size: 0.97rem;
  color: #555;
  line-height: 1.75;
}
.offer-note {
  background: var(--cream);
  border-left: 3px solid var(--gold);
  padding: 1.2rem 1.5rem;
  max-width: 680px;
  margin: 0 auto;
}
.offer-note p {
  font-size: 1rem;
  color: #444;
  line-height: 1.85;
  font-style: italic;
}
.offer-note strong { color: var(--ink); font-style: normal; }
@media (max-width: 720px) {
  .offer-cards { grid-template-columns: 1fr; }
  .offer-block { margin: 0 -1.5rem 3rem; padding: 3rem 1.5rem; }
}

</style>
<style>
/* ── A11Y: Skip link ── */
.skip-link {
  position: absolute; top: -100%; left: 1rem;
  background: var(--red); color: #fff;
  padding: 0.55rem 1.2rem;
  font-family: 'Cinzel', serif; font-size: 0.78rem;
  letter-spacing: 0.12em; text-transform: uppercase;
  text-decoration: none; z-index: 99999;
  transition: top 0.2s ease;
  border-bottom: 2px solid var(--gold);
}
.skip-link:focus { top: 0; }

/* ── Reading progress bar ── */
.reading-progress {
  position: fixed; top: 0; left: 0;
  width: 0%; height: 2px;
  background: linear-gradient(90deg, var(--red), var(--gold));
  z-index: 99998; pointer-events: none;
  transition: width 0.1s linear;
}

/* ── Page transition ── */
body { opacity: 1; transition: opacity 0.35s ease; }
body.page-leaving { opacity: 0; }

/* ── Reveal animácie ── */
.reveal {
  opacity: 0; transform: translateY(24px);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.reveal.is-visible { opacity: 1; transform: translateY(0); }
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }

/* ── prefers-reduced-motion ── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* ── scroll-margin-top pre zakotvené sekcie ── */
section[id], div[id] { scroll-margin-top: 72px; }
</style>
</head>
